<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".Activity_Labs">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity Exploitation"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 1 - Basic exported activity | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 2 - Intent with extras | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 3 - Intent with a data URI | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 4 - State machine | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag4"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 5 - Intent in intent | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag5"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 6 - Not exported | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag6"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 7 - Activity lifecycle tricks | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag7"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
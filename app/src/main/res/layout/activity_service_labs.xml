<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".Service_Labs">
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service Exploitation"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 24 - Basic Service Start | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag24"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 25 - Service Lifecycle | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag25"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 26 - Basic message handler | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag26"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 27 - Hijack pending intent | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag27"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 28 - Basic AIDL Service | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag28"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="10dp"
                android:text="Flag 29 - AIDL Service | Exploit"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                android:onClick="Flag29"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>